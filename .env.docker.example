# Copy to .env for docker compose: cp .env.docker.example .env

# Auth mode: local | cognito
AUTH_MODE=local

# Required in production — generate with: openssl rand -base64 32
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=8h

# Local auth accounts (AUTH_MODE=local only)
LOCAL_ADMIN_EMAIL=admin@motherson.com
LOCAL_ADMIN_PASSWORD=Admin123!
LOCAL_USER_EMAIL=user@motherson.com
LOCAL_USER_PASSWORD=User123!

# AWS Cognito (AUTH_MODE=cognito)
COGNITO_REGION=us-east-1
COGNITO_USER_POOL_ID=
COGNITO_CLIENT_ID=
COGNITO_ADMIN_GROUP=admin
COGNITO_USER_GROUP=user

# Set true on first deploy to load 3 sample quotes
SEED_ON_START=false
